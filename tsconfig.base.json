{
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "paths": {
      "@libs/shared-types": ["libs/shared/types/src/index.ts"],
      "@libs/server-cache": ["libs/server/cache/src/index.ts"],
      "@libs/server-neo4j": ["libs/server/neo4j/src/index.ts"],
      "@libs/server-graph": ["libs/server/graph/src/index.ts"],
      "@libs/server-rate-limit": ["libs/server/rate-limit/src/index.ts"],
      "@libs/server-health": ["libs/server/health/src/index.ts"],
    },
  },
}
